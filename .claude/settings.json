{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "async": true,
            "statusMessage": "Updating graphify code graph...",
            "command": "grep -q \"\\.dart\" && \"/c/Users/felip/AppData/Roaming/Python/Python314/Scripts/graphify.exe\" update \"C:/Users/felip/Documents/digimon\" >/dev/null 2>&1 || true"
          }
        ]
      }
    ]
  }
}
